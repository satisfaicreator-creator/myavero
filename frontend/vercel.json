{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "buildCommand": "yarn build",
  "installCommand": "yarn install",
  "outputDirectory": "build",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!api/|api$|_next/|.*\\..*|admin/api).*)", "destination": "/index.html" }
  ]
}
